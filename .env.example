# Copy to .env and fill in for local dev. .env is gitignored.
# NEVER commit real credentials.

# --- ISE target (deployment VIP) ---
ISE_BASE_URL=https://ise-vip.example.local
# Optional overrides; default derived from ISE_BASE_URL if unset.
ISE_ERS_BASE_URL=
ISE_MNT_BASE_URL=
ISE_VERSION=3.2

# --- Auth model ---
# passthrough = client presents ISE creds, server validates and issues an MCP session id
# service_account = server uses ISE_USERNAME/ISE_PASSWORD below (non-interactive clients)
ISE_AUTH_MODE=passthrough

# Only used in service_account mode. Placeholders only.
ISE_USERNAME=REPLACE_ME_SERVICE_ACCOUNT
ISE_PASSWORD=REPLACE_ME_PASSWORD
# Optional: pre-encoded base64 "user:pass"; overrides USERNAME/PASSWORD if set.
ISE_ENCODED_AUTH=

# --- Read/write safety ---
ISE_MCP_MODE=readonly
ISE_ENABLE_DANGEROUS_TOOLS=false

# --- Transport / TLS ---
ISE_VERIFY_SSL=true
ISE_TIMEOUT_SECONDS=30
ISE_RATE_LIMIT_WAIT=true

# --- Sessions (passthrough) ---
ISE_SESSION_TTL_SECONDS=3600
ISE_SESSION_IDLE_TIMEOUT_SECONDS=900
MCP_SESSION_HEADER=X-MCP-Session

# --- Logging / audit ---
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true

# --- Tool + scope gating (comma-separated; empty = no restriction) ---
ISE_ALLOWED_TOOLS=
ISE_DISABLED_TOOLS=
ISE_ALLOWED_ENDPOINT_GROUPS=
ISE_ALLOWED_DEVICE_GROUPS=
ISE_ALLOWED_SITES=

# --- Paging / output ---
ISE_DEFAULT_PAGE_SIZE=50
ISE_MAX_PAGE_SIZE=500
ISE_INCLUDE_RAW_DEFAULT=false

# --- Server bind (HTTP transport) ---
MCP_HOST=0.0.0.0
MCP_PORT=8005
MCP_TRANSPORT=streamable-http

# =========================================================
# RESERVED for future auth providers (phase 2+). Not required in v1.
# =========================================================
# MCP_AUTH_PROVIDER=
# MCP_API_KEYS=
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_ALLOWED_GROUPS=
# JWT_ISSUER=
# JWT_AUDIENCE=
# JWT_JWKS_URL=
